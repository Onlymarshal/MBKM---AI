    {
      "parameters": {
        "jsCode": "try {\n\nconst data = $json.output;\n\n// Validasi nama kandidat kosong\nif (!data.nama_kandidat || data.nama_kandidat.trim() === \"\") {\n  throw new Error(\n    \"Informasi kandidat tidak lengkap\"\n  );\n}\n\n// Validasi posisi kosong\nif (!data.posisi || data.posisi.trim() === \"\") {\n  throw new Error(\n    \"Informasi kandidat tidak lengkap\"\n  );\n}\n\n// Validasi placeholder AI\nconst invalidValues = [\n  \"Tidak disebutkan\",\n  \"Unknown\",\n  \"N/A\",\n  \"-\"\n];\n\nif (\n  invalidValues.includes(data.nama_kandidat) ||\n  invalidValues.includes(data.posisi)\n) {\n  throw new Error(\n    \"Informasi kandidat tidak valid atau tidak lengkap\"\n  );\n}\n\n// Validasi skor teknis\nif (isNaN(data.skor_teknis)) {\n  throw new Error(\n    \"Skor teknis kandidat tidak valid\"\n  );\n}\n\n// Validasi skor komunikasi\nif (isNaN(data.skor_komunikasi)) {\n  throw new Error(\n    \"Skor komunikasi kandidat tidak valid\"\n  );\n}\n\n// Validasi range skor\nif (\n  data.skor_teknis < 0 ||\n  data.skor_teknis > 100\n) {\n  throw new Error(\n    \"Skor teknis harus berada di antara 0-100\"\n  );\n}\n\nif (\n  data.skor_komunikasi < 0 ||\n  data.skor_komunikasi > 100\n) {\n  throw new Error(\n    \"Skor komunikasi harus berada di antara 0-100\"\n  );\n}\n\n// Validasi skor default AI\nif (\n  data.skor_teknis === 50 &&\n  data.skor_komunikasi === 50\n) {\n  throw new Error(\n    \"AI gagal menghasilkan evaluasi kandidat yang valid\"\n  );\n}\n\n// Validasi gaji\ndata.catatan_gaji =\nparseInt(data.catatan_gaji);\n\nif (isNaN(data.catatan_gaji)) {\n  throw new Error(\n    \"Ekspektasi gaji kandidat tidak valid\"\n  );\n}\n\nif (data.catatan_gaji <= 0) {\n  throw new Error(\n    \"Ekspektasi gaji kandidat tidak valid\"\n  );\n}\n\n// Fallback kelebihan\nif (\n  !data.analisis_kelebihan ||\n  data.analisis_kelebihan.trim() === \"\"\n) {\n  data.analisis_kelebihan =\n    \"Tidak ada kelebihan yang signifikan\";\n}\n\n// Fallback kekurangan\nif (\n  !data.analisis_kekurangan ||\n  data.analisis_kekurangan.trim() === \"\"\n) {\n  data.analisis_kekurangan =\n    \"Tidak ada kekurangan yang signifikan\";\n}\n\n// Hitung overall score\nconst overall =\nMath.round(\n  (data.skor_teknis * 0.6) +\n  (data.skor_komunikasi * 0.4)\n);\n\n// Rule-based recommendation\nlet final_recommendation = \"\";\n\nif (overall >= 85) {\n  final_recommendation = \"Lolos\";\n} else if (overall >= 70) {\n  final_recommendation = \"Cadangan\";\n} else {\n  final_recommendation = \"Tolak\";\n}\n\n// Format salary Indonesia\nconst formatted_salary =\nnew Intl.NumberFormat(\"id-ID\")\n.format(data.catatan_gaji);\n\n// Status emoji\nlet status_emoji = \"\";\n\nif (final_recommendation === \"Lolos\") {\n  status_emoji = \"🟢\";\n} else if (\n  final_recommendation === \"Cadangan\"\n) {\n  status_emoji = \"🟡\";\n} else {\n  status_emoji = \"🔴\";\n}\n\n// Return sukses\nreturn [{\n  json: {\n\n    success: true,\n\n    ...data,\n\n    overall_score: overall,\n\n    rekomendasi_final:\n      final_recommendation,\n\n    formatted_salary,\n\n    status_emoji\n\n  }\n}];\n\n} catch(error) {\n\nreturn [{\n  json: {\n\n    success: false,\n\n    error_message: error.message\n\n  }\n}];\n\n}"
      },
